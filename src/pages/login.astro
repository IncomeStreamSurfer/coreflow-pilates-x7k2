---
import Base from '../layouts/Base.astro';

// @ts-expect-error loose locals typing
const user = Astro.locals.user;
const next = Astro.url.searchParams.get('next') ?? '/admin';
if (user) return Astro.redirect(next);

const sent = Astro.url.searchParams.get('sent') === '1';
const error = Astro.url.searchParams.get('error') ?? '';
const renderedAt = Date.now();
---
<Base title="Studio Login | Core & Flow Pilates" description="Sign in to manage Core & Flow Pilates." noindex={true}>
  <section class="max-w-md mx-auto px-5 sm:px-8 pt-20 pb-16 md:pt-28">
    <h1 class="font-display text-4xl tracking-tight text-ink text-center">Studio login</h1>
    <p class="mt-3 text-center text-sm text-ink-soft">We'll email you a magic link — no password needed.</p>
    {sent ? (
      <div class="mt-8 border border-sage/40 rounded-lg bg-sage-light p-8 text-center">
        <p class="font-semibold text-ink">Check your inbox</p>
        <p class="mt-2 text-sm text-ink-soft">If that address has studio access, a sign-in link is on its way. It expires in one hour.</p>
      </div>
    ) : (
      <form method="POST" action="/api/auth/login" class="mt-8 border border-ink/10 rounded-lg bg-paper p-7 space-y-5">
        {error && (
          <div class="rounded-lg border border-clay/40 bg-clay/10 px-4 py-3 text-sm text-ink" role="alert">
            {error === 'rate' ? 'Too many attempts — wait a minute and try again.' : 'Could not send the link — check the address and try again.'}
          </div>
        )}
        <div>
          <label for="email" class="block text-sm font-semibold text-ink">Email</label>
          <input id="email" name="email" type="email" required maxlength="200" autocomplete="email" class="mt-2 w-full rounded-md border border-ink/20 bg-paper px-4 py-3 text-sm focus:border-sage focus:outline-none" placeholder="you@example.com" />
        </div>
        <p class="hp-field" aria-hidden="true">
          <label>Website <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
        </p>
        <input type="hidden" name="renderedAt" value={renderedAt} />
        <input type="hidden" name="next" value={next} />
        <button type="submit" class="w-full inline-flex items-center justify-center rounded-full bg-sage px-6 py-3 text-sm font-semibold text-paper hover:bg-sage-deep transition-colors">Email me a sign-in link</button>
      </form>
    )}
  </section>
</Base>
