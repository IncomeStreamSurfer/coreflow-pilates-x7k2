---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';
import { safeHtml } from '../lib/sanitize';
import { breadcrumbSchema, siteUrl } from '../lib/seo';

const supabase = anonClient();
let pageRow: any = null;
let testimonials: any[] = [];
if (supabase) {
  const [{ data: p }, { data: t }] = await Promise.all([
    supabase.from('pages').select('*').eq('slug', 'testimonials').not('published_at', 'is', null).maybeSingle(),
    supabase.from('testimonials').select('*').order('sort_order'),
  ]);
  pageRow = p;
  testimonials = t ?? [];
}

const site = siteUrl(Astro.site);
const schemas = [
  breadcrumbSchema(site, [
    { name: 'Home', path: '/' },
    { name: 'Member stories', path: '/testimonials' },
  ]),
];
---
<Base
  title={pageRow?.meta_title ?? 'Reviews & Member Stories | Core & Flow Pilates Austin'}
  description={pageRow?.meta_description ?? 'What members say about classes at Core & Flow Pilates in Austin.'}
  structuredData={schemas}
>
  <section class="max-w-6xl mx-auto px-5 sm:px-8 pt-16 pb-8 md:pt-24">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sage">Member stories</p>
    <h1 class="mt-3 font-display text-4xl md:text-5xl tracking-tight text-ink">{pageRow?.title ?? 'Member Stories'}</h1>
    <div class="mt-6 max-w-3xl prose-body" set:html={safeHtml(pageRow?.body_html)} />
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-8 pb-16">
    {testimonials.length === 0 ? (
      <p class="text-ink-soft py-12">Stories are being collected — be the first: <a href="/book" class="underline underline-offset-4 decoration-sage">take a class</a> and tell us how it went.</p>
    ) : (
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 [&>*]:break-inside-avoid space-y-6">
        {testimonials.map((t) => (
          <figure class="border border-ink/10 rounded-lg bg-paper p-6">
            <div class="text-sage" aria-label={`${t.rating} out of 5 stars`}>{'★'.repeat(t.rating)}</div>
            <blockquote class="mt-3 text-ink leading-relaxed">"{t.quote}"</blockquote>
            <figcaption class="mt-4 text-sm text-ink-soft">{t.author_name}{t.author_title ? ` · ${t.author_title}` : ''}</figcaption>
          </figure>
        ))}
      </div>
    )}
    <div class="mt-14 border border-ink/10 rounded-lg bg-paper-dark p-8 md:p-10 flex flex-wrap items-center justify-between gap-6">
      <div>
        <h2 class="font-display text-2xl md:text-3xl text-ink">Write the next one</h2>
        <p class="mt-2 text-ink-soft">Your first class is $15. See <a href="/classes" class="underline underline-offset-4 decoration-sage hover:text-sage-deep">what we teach</a> and grab a spot.</p>
      </div>
      <a href="/book" class="inline-flex items-center rounded-full bg-sage px-7 py-3 text-base font-semibold text-paper hover:bg-sage-deep transition-all hover:-translate-y-0.5">Book a class</a>
    </div>
  </section>
</Base>
