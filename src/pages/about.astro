---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';
import { safeHtml } from '../lib/sanitize';
import { breadcrumbSchema, siteUrl } from '../lib/seo';

const supabase = anonClient();
let pageRow: any = null;
let instructors: any[] = [];
if (supabase) {
  const [{ data: p }, { data: i }] = await Promise.all([
    supabase.from('pages').select('*').eq('slug', 'about').not('published_at', 'is', null).maybeSingle(),
    supabase.from('instructors').select('slug, name, title, image_url').not('published_at', 'is', null).order('sort_order'),
  ]);
  pageRow = p;
  instructors = i ?? [];
}

const site = siteUrl(Astro.site);
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: pageRow?.title ?? 'About Core & Flow Pilates',
    url: `${site}/about`,
  },
  breadcrumbSchema(site, [
    { name: 'Home', path: '/' },
    { name: 'About', path: '/about' },
  ]),
];
---
<Base
  title={pageRow?.meta_title ?? 'About Us | Core & Flow Pilates Austin'}
  description={pageRow?.meta_description ?? 'The story of Core & Flow Pilates, a boutique Austin studio.'}
  structuredData={schemas}
>
  <section class="max-w-6xl mx-auto px-5 sm:px-8 pt-16 md:pt-24 grid md:grid-cols-12 gap-12">
    <div class="md:col-span-7">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sage">Our story</p>
      <h1 class="mt-3 font-display text-4xl md:text-5xl tracking-tight text-ink">{pageRow?.title ?? 'About Core & Flow Pilates'}</h1>
      <article class="mt-6 prose-body" set:html={safeHtml(pageRow?.body_html)} />
    </div>
    <div class="md:col-span-5 space-y-6">
      <img src="https://picsum.photos/seed/coreflow-studio/800/600" alt="The reformer room at Core & Flow Pilates on South Lamar, Austin" class="w-full h-64 object-cover rounded-lg border border-ink/10" width="800" height="600" loading="lazy" />
      <div class="border border-ink/10 rounded-lg bg-paper-dark p-6">
        <h2 class="font-display text-xl text-ink">Visit us</h2>
        <p class="mt-3 text-sm text-ink-soft leading-relaxed">1408 S Lamar Blvd, Suite 210<br />Austin, TX 78704</p>
        <p class="mt-2 text-sm text-ink-soft">Mon–Fri 6:00a–8:00p · Sat–Sun 8:00a–2:00p</p>
        <p class="mt-2 text-sm"><a href="tel:+15125550182" class="text-sage-deep underline underline-offset-2 hover:text-ink transition-colors">(512) 555-0182</a></p>
        <a href="/contact" class="mt-4 inline-flex items-center rounded-full border border-ink/20 px-5 py-2 text-sm font-semibold text-ink hover:bg-ink hover:text-paper transition-colors">Get in touch</a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-8 py-16">
    <h2 class="font-display text-3xl tracking-tight text-ink">The people who teach here</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-3">
      {instructors.map((p) => (
        <a href={`/instructors/${p.slug}`} class="group flex items-center gap-4 border border-ink/10 rounded-lg bg-paper p-4 hover:border-sage transition-colors">
          <img src={p.image_url} alt={p.name} class="w-16 h-16 rounded-full object-cover" width="64" height="64" loading="lazy" />
          <div>
            <p class="font-semibold text-ink group-hover:text-sage-deep transition-colors">{p.name}</p>
            <p class="text-xs text-ink-soft">{p.title}</p>
          </div>
        </a>
      ))}
    </div>
    <p class="mt-8 text-ink-soft">Ready to move? <a href="/classes" class="underline underline-offset-4 decoration-sage hover:text-sage-deep">Browse the classes</a> or <a href="/book" class="underline underline-offset-4 decoration-sage hover:text-sage-deep">book straight in</a>.</p>
  </section>
</Base>
