---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';
import { safeHtml } from '../../lib/sanitize';
import { formatPrice } from '../../lib/format';
import { breadcrumbSchema, siteUrl } from '../../lib/seo';

const supabase = anonClient();
let pageRow: any = null;
let classes: any[] = [];
if (supabase) {
  const [{ data: p }, { data: c }] = await Promise.all([
    supabase.from('pages').select('*').eq('slug', 'classes').not('published_at', 'is', null).maybeSingle(),
    supabase.from('classes').select('*').not('published_at', 'is', null).order('sort_order'),
  ]);
  pageRow = p;
  classes = c ?? [];
}

const site = siteUrl(Astro.site);
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: pageRow?.title ?? 'Our Pilates Classes',
    description: pageRow?.meta_description ?? '',
    url: `${site}/classes`,
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: classes.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: c.name,
        url: `${site}/classes/${c.slug}`,
      })),
    },
  },
  breadcrumbSchema(site, [
    { name: 'Home', path: '/' },
    { name: 'Classes', path: '/classes' },
  ]),
];
---
<Base
  title={pageRow?.meta_title ?? 'Pilates Classes | Core & Flow Pilates'}
  description={pageRow?.meta_description ?? 'Explore mat, reformer, barre fusion, and prenatal Pilates classes at Core & Flow Pilates in Austin.'}
  structuredData={schemas}
>
  <section class="max-w-6xl mx-auto px-5 sm:px-8 pt-16 pb-8 md:pt-24">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sage">Classes</p>
    <h1 class="mt-3 font-display text-4xl md:text-5xl tracking-tight text-ink">{pageRow?.title ?? 'Our Pilates Classes'}</h1>
    <div class="mt-6 max-w-3xl prose-body" set:html={safeHtml(pageRow?.body_html)} />
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-8 pb-8">
    {classes.length === 0 ? (
      <p class="text-ink-soft py-12">Classes are being added — check back shortly or <a href="/contact" class="underline underline-offset-4 decoration-sage">get in touch</a>.</p>
    ) : (
      <div class="grid gap-8 md:grid-cols-2">
        {classes.map((c) => (
          <a href={`/classes/${c.slug}`} class="group grid sm:grid-cols-5 border border-ink/10 rounded-lg overflow-hidden bg-paper hover:border-sage transition-colors">
            <img src={c.image_url} alt={`${c.name} at Core & Flow Pilates Austin`} class="sm:col-span-2 w-full h-48 sm:h-full object-cover" width="600" height="400" loading="lazy" />
            <div class="sm:col-span-3 p-6">
              <div class="flex items-baseline justify-between gap-3">
                <h2 class="font-display text-2xl text-ink group-hover:text-sage-deep transition-colors">{c.name}</h2>
                <span class="text-sm font-semibold text-sage whitespace-nowrap">{formatPrice(c.price_pence)}</span>
              </div>
              <p class="mt-1 text-xs uppercase tracking-wider text-ink-soft">{c.duration_minutes} min · {c.level} · max {c.capacity}</p>
              <p class="mt-3 text-sm leading-relaxed text-ink-soft">{c.description}</p>
              <p class="mt-4 text-sm font-semibold text-sage group-hover:text-sage-deep transition-colors">About this class →</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-8 py-14">
    <div class="border border-ink/10 rounded-lg bg-paper-dark p-8 md:p-10 flex flex-wrap items-center justify-between gap-6">
      <div>
        <h2 class="font-display text-2xl md:text-3xl text-ink">Found your class?</h2>
        <p class="mt-2 text-ink-soft">Check <a href="/schedule" class="underline underline-offset-4 decoration-sage hover:text-sage-deep">this week's schedule</a> for times, or book straight away.</p>
      </div>
      <a href="/book" class="inline-flex items-center rounded-full bg-sage px-7 py-3 text-base font-semibold text-paper hover:bg-sage-deep transition-all hover:-translate-y-0.5">Book a class</a>
    </div>
  </section>
</Base>
