---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';
import { safeHtml } from '../../lib/sanitize';
import { formatPrice, formatSessionDay, formatSessionTime } from '../../lib/format';
import { breadcrumbSchema, siteUrl } from '../../lib/seo';

const { slug } = Astro.params;
const supabase = anonClient();
if (!supabase) return new Response('Service unavailable', { status: 500 });

const { data: cls } = await supabase.from('classes').select('*').eq('slug', slug).not('published_at', 'is', null).maybeSingle();
if (!cls) return new Response(null, { status: 404 });

const [{ data: faqs }, { data: sessions }] = await Promise.all([
  supabase.from('faqs').select('*').eq('page_slug', `classes/${slug}`).order('sort_order'),
  supabase
    .from('class_sessions')
    .select('id, starts_at, capacity, booked_count, instructors(name, slug)')
    .eq('class_id', cls.id)
    .eq('canceled', false)
    .gte('starts_at', new Date().toISOString())
    .order('starts_at')
    .limit(6),
]);

const site = siteUrl(Astro.site);
const schemas: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: cls.name,
    description: cls.description,
    serviceType: `${cls.name} class`,
    provider: { '@type': 'ExerciseGym', name: 'Core & Flow Pilates', url: site },
    areaServed: 'Austin, TX',
    offers: { '@type': 'Offer', price: (cls.price_pence / 100).toFixed(2), priceCurrency: 'USD' },
    url: `${site}/classes/${cls.slug}`,
  },
  breadcrumbSchema(site, [
    { name: 'Home', path: '/' },
    { name: 'Classes', path: '/classes' },
    { name: cls.name, path: `/classes/${cls.slug}` },
  ]),
];
if (faqs && faqs.length > 0) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer_html.replace(/<[^>]+>/g, '') },
    })),
  });
}
---
<Base
  title={cls.meta_title ?? `${cls.name} | Core & Flow Pilates`}
  description={cls.meta_description ?? cls.description}
  ogImage={cls.image_url}
  structuredData={schemas}
>
  <section class="max-w-6xl mx-auto px-5 sm:px-8 pt-16 md:pt-24 grid md:grid-cols-12 gap-10">
    <div class="md:col-span-7">
      <nav class="text-sm text-ink-soft" aria-label="Breadcrumb">
        <a href="/classes" class="hover:text-ink transition-colors">Classes</a> <span class="mx-1">/</span> <span class="text-ink">{cls.name}</span>
      </nav>
      <h1 class="mt-4 font-display text-4xl md:text-5xl tracking-tight text-ink">{cls.name} Classes</h1>
      {cls.tagline && <p class="mt-3 text-xl text-sage-deep font-display">{cls.tagline}</p>}
      <p class="mt-5 text-lg leading-relaxed text-ink-soft">{cls.description}</p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm">
        <span class="rounded-full bg-sage-light text-sage-deep px-4 py-1.5 font-medium">{cls.duration_minutes} minutes</span>
        <span class="rounded-full bg-sage-light text-sage-deep px-4 py-1.5 font-medium">{cls.level}</span>
        <span class="rounded-full bg-sage-light text-sage-deep px-4 py-1.5 font-medium">Max {cls.capacity} people</span>
        <span class="rounded-full bg-sage-light text-sage-deep px-4 py-1.5 font-medium">{formatPrice(cls.price_pence)} per class</span>
      </div>
      <div class="mt-8 flex items-center gap-6">
        <a href="/book" class="inline-flex items-center rounded-full bg-sage px-7 py-3 text-base font-semibold text-paper hover:bg-sage-deep transition-all hover:-translate-y-0.5">Book {cls.name}</a>
        <a href="/schedule" class="text-base font-medium text-ink underline underline-offset-4 decoration-sage hover:text-sage-deep transition-colors">See all times</a>
      </div>
    </div>
    <div class="md:col-span-5">
      <img src={cls.image_url} alt={`${cls.name} class at Core & Flow Pilates in Austin`} class="w-full h-72 md:h-96 object-cover rounded-lg border border-ink/10" width="1200" height="800" />
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-8 py-14 grid md:grid-cols-12 gap-12">
    <article class="md:col-span-7 prose-body" set:html={safeHtml(cls.body_html)} />
    <aside class="md:col-span-5">
      <div class="border border-ink/10 rounded-lg bg-paper-dark p-6 sticky top-24">
        <h2 class="font-display text-xl text-ink">Upcoming {cls.name} classes</h2>
        {(sessions ?? []).length === 0 ? (
          <p class="mt-3 text-sm text-ink-soft">New times are being scheduled — <a href="/contact" class="underline underline-offset-2">contact us</a> and we'll save you a spot.</p>
        ) : (
          <ul class="mt-4 space-y-3">
            {(sessions ?? []).map((s: any) => {
              const left = s.capacity - s.booked_count;
              return (
                <li class="flex items-center justify-between gap-3 border-b border-ink/10 pb-3 last:border-0">
                  <div>
                    <p class="text-sm font-semibold text-ink">{formatSessionDay(s.starts_at)}</p>
                    <p class="text-xs text-ink-soft">{formatSessionTime(s.starts_at)} · {s.instructors?.name}</p>
                  </div>
                  {left > 0 ? (
                    <a href={`/book?session=${s.id}`} class="rounded-full bg-sage px-4 py-1.5 text-xs font-semibold text-paper hover:bg-sage-deep transition-colors whitespace-nowrap">Book · {left} left</a>
                  ) : (
                    <span class="rounded-full bg-ink/10 px-4 py-1.5 text-xs font-semibold text-ink-soft whitespace-nowrap">Full</span>
                  )}
                </li>
              );
            })}
          </ul>
        )}
        <a href="/schedule" class="mt-4 inline-block text-sm font-medium text-sage-deep underline underline-offset-4 hover:text-ink transition-colors">Full weekly schedule →</a>
      </div>
    </aside>
  </section>

  {faqs && faqs.length > 0 && (
    <section class="max-w-3xl mx-auto px-5 sm:px-8 py-14">
      <h2 class="font-display text-3xl tracking-tight text-ink">Questions, answered</h2>
      <div class="mt-8 divide-y divide-ink/10 border-y border-ink/10">
        {faqs.map((f) => (
          <details class="group py-5">
            <summary class="cursor-pointer list-none flex items-center justify-between gap-4 font-semibold text-ink hover:text-sage-deep transition-colors">
              {f.question}
              <span class="text-sage transition-transform group-open:rotate-45 text-xl leading-none">+</span>
            </summary>
            <div class="mt-3 prose-body text-sm" set:html={safeHtml(f.answer_html)} />
          </details>
        ))}
      </div>
      <p class="mt-8 text-ink-soft text-sm">Still curious? Meet <a href="/instructors" class="underline underline-offset-4 decoration-sage hover:text-sage-deep">our instructors</a> or <a href="/contact" class="underline underline-offset-4 decoration-sage hover:text-sage-deep">send us a question</a>.</p>
    </section>
  )}
</Base>
