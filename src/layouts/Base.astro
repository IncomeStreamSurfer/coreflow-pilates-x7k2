---
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown>[];
}

const { title, description, ogImage, ogType, noindex, structuredData = [] } = Astro.props;

const site = import.meta.env.PUBLIC_SITE_URL || Astro.site?.toString().replace(/\/$/, '') || '';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'ExerciseGym',
  name: 'Core & Flow Pilates',
  description: 'Boutique Pilates studio in Austin, TX offering mat, reformer, prenatal, and barre fusion classes with certified instructors and online booking.',
  url: site || undefined,
  telephone: '+1-512-555-0182',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1408 S Lamar Blvd, Suite 210',
    addressLocality: 'Austin',
    addressRegion: 'TX',
    postalCode: '78704',
    addressCountry: 'US',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 30.2554, longitude: -97.7645 },
  areaServed: 'Austin, TX',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '06:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday', 'Sunday'], opens: '08:00', closes: '14:00' },
  ],
};

const allSchemas = [localBusiness, ...structuredData];

const nav = [
  { href: '/classes', label: 'Classes' },
  { href: '/schedule', label: 'Schedule' },
  { href: '/instructors', label: 'Instructors' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <SEOHead {title} {description} {ogImage} {ogType} {noindex} structuredData={allSchemas} />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 bg-paper/85 backdrop-blur-md border-b border-ink/10">
      <div class="max-w-6xl mx-auto px-5 sm:px-8 h-16 flex items-center justify-between">
        <a href="/" class="font-display text-xl tracking-tight text-ink hover:text-sage-deep transition-colors">
          Core <span class="text-sage">&amp;</span> Flow
        </a>
        <nav class="hidden md:flex items-center gap-7 text-sm font-medium text-ink-soft">
          {nav.map((item) => (
            <a href={item.href} class="hover:text-ink transition-colors">{item.label}</a>
          ))}
        </nav>
        <div class="flex items-center gap-4">
          <a href="/book" class="inline-flex items-center rounded-full bg-sage px-5 py-2 text-sm font-semibold text-paper hover:bg-sage-deep transition-all hover:-translate-y-px">
            Book a class
          </a>
          <button id="mobile-toggle" class="md:hidden text-ink" aria-label="Open menu">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="hidden md:hidden border-t border-ink/10 bg-paper px-5 py-4">
        <nav class="flex flex-col gap-3 text-sm font-medium text-ink-soft">
          {nav.map((item) => (
            <a href={item.href} class="hover:text-ink transition-colors py-1">{item.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-ink text-paper/80 mt-24">
      <div class="max-w-6xl mx-auto px-5 sm:px-8 py-14 grid gap-10 md:grid-cols-4">
        <div>
          <p class="font-display text-lg text-paper">Core <span class="text-sage-light">&amp;</span> Flow Pilates</p>
          <p class="mt-3 text-sm leading-relaxed">1408 S Lamar Blvd, Suite 210<br />Austin, TX 78704</p>
          <p class="mt-2 text-sm"><a href="tel:+15125550182" class="hover:text-paper transition-colors">(512) 555-0182</a></p>
        </div>
        <div>
          <p class="text-sm font-semibold text-paper uppercase tracking-wider">Classes</p>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a href="/classes/mat-pilates" class="hover:text-paper transition-colors">Mat Pilates</a></li>
            <li><a href="/classes/reformer-pilates" class="hover:text-paper transition-colors">Reformer Pilates</a></li>
            <li><a href="/classes/prenatal-pilates" class="hover:text-paper transition-colors">Prenatal Pilates</a></li>
            <li><a href="/classes/barre-fusion" class="hover:text-paper transition-colors">Barre Fusion</a></li>
          </ul>
        </div>
        <div>
          <p class="text-sm font-semibold text-paper uppercase tracking-wider">Studio</p>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a href="/schedule" class="hover:text-paper transition-colors">Class schedule</a></li>
            <li><a href="/instructors" class="hover:text-paper transition-colors">Instructors</a></li>
            <li><a href="/about" class="hover:text-paper transition-colors">About the studio</a></li>
            <li><a href="/contact" class="hover:text-paper transition-colors">Contact</a></li>
          </ul>
        </div>
        <div>
          <p class="text-sm font-semibold text-paper uppercase tracking-wider">Hours</p>
          <ul class="mt-3 space-y-2 text-sm">
            <li>Mon–Fri · 6:00a – 8:00p</li>
            <li>Sat–Sun · 8:00a – 2:00p</li>
          </ul>
          <a href="/book" class="mt-5 inline-flex items-center rounded-full border border-paper/30 px-4 py-1.5 text-sm hover:bg-paper hover:text-ink transition-colors">Book a class</a>
        </div>
      </div>
      <div class="border-t border-paper/10">
        <div class="max-w-6xl mx-auto px-5 sm:px-8 py-5 text-xs flex flex-wrap items-center justify-between gap-2 text-paper/50">
          <p>© {year} Core &amp; Flow Pilates. All rights reserved.</p>
          <p><a href="/login" class="hover:text-paper/80 transition-colors">Studio login</a></p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('mobile-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
